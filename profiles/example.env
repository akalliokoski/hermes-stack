# Per-profile credentials for a Hermes agent.
# Copy this file to profiles/<name>.env and fill in the tokens for that profile.
# This file is loaded in addition to the shared .env — it can override any key.
#
# Keys here are profile-specific (different bot accounts).
# Shared keys (OPENROUTER_API_KEY, POSTGRES_*, etc.) stay in .env.

# Messaging platform tokens — use a separate bot/account per profile
# so each agent has its own identity and the gateway token-lock can enforce isolation.
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_API_KEY=
SIGNAL_PHONE_NUMBER=
