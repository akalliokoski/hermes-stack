# Secrets
.env
profiles/*.env    # per-profile credentials (copy from profiles/example.env)

# Agent submodule placeholder – remove once submodule is configured
agent/.gitkeep

# Syncthing index / temp files
.stfolder
.stignore
*.tmp

# Shared sync folder (managed by Syncthing, not git)
sync/

# Local dev backups (managed by litestream + docker-volume-backup)
backups/

# Local dev litestream config override
litestream.local.yml

# OS
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.py[cod]

# Local scratch artifacts
/tmp/
tmp/
.hermes/plans/
audio/.audio-work/
