# Copy to .env and fill in values before running docker compose
# Never commit .env to git

# ── Hermes agent ──────────────────────────────────────────────────────────────
# Which profile to activate (matches a folder under ./profiles/)
HERMES_PROFILE=default

# ── Gateway security ──────────────────────────────────────────────────────────
# Restrict which Telegram/Discord users can talk to the agent (comma-separated IDs)
# NEVER set GATEWAY_ALLOW_ALL_USERS=true in production
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# DISCORD_ALLOWED_USERS=123456789,987654321

# Optional: OpenAI-compatible API server (for Open WebUI etc.)
# API_SERVER_ENABLED=true
# API_SERVER_KEY=changeme

# LLM used by the agent for reasoning and responses
# Providers: anthropic | openai | openrouter
HERMES_LLM_PROVIDER=anthropic
HERMES_LLM_MODEL=claude-sonnet-4-6
HERMES_LLM_API_KEY=your-api-key-here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=changeme
POSTGRES_DB=firecrawl

# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Random string for the Bull queue admin panel at /admin/<key>/queues
BULL_AUTH_KEY=changeme

# Optional: enable AI-powered extraction / parse features
# OPENAI_API_KEY=sk-...
# LLAMAPARSE_API_KEY=...

# ── Hindsight ─────────────────────────────────────────────────────────────────
# LLM used internally by Hindsight for memory extraction and reflection
# Providers: anthropic | openai | gemini | groq | ollama
HINDSIGHT_LLM_PROVIDER=anthropic
HINDSIGHT_LLM_MODEL=claude-sonnet-4-6
HINDSIGHT_LLM_API_KEY=your-api-key-here
HINDSIGHT_DB_PASSWORD=changeme

# ── VPS deployment (used by deploy.sh on your MacBook) ───────────────────────
# Use Tailscale hostname (e.g. my-vps) or Tailscale IP (100.x.x.x)
VPS_HOST=user@my-vps
VPS_DIR=/opt/hermes
