# Copy to .env and fill in values before running docker compose
# Never commit .env to git

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=changeme
POSTGRES_DB=firecrawl

# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Random string for the Bull queue admin panel at /admin/<key>/queues
BULL_AUTH_KEY=changeme

# Optional: enable AI-powered extraction / parse features
# OPENAI_API_KEY=sk-...
# LLAMAPARSE_API_KEY=...

# ── VPS deployment (used by deploy.sh on your MacBook) ───────────────────────
VPS_HOST=user@your-vps-ip
VPS_DIR=/opt/hermes
